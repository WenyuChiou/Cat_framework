# CAT411 Earthquake Risk Agent — Environment Variables
# Copy this file to .env and fill in your API key.

# LLM Provider: "openai", "anthropic", "ollama", or "nvidia"
CAT411_LLM_PROVIDER=openai

# API Keys — set the one matching your provider
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# NVIDIA_API_KEY=nvapi-...   # Get free key at https://build.nvidia.com/

# Optional: model overrides
# CAT411_OPENAI_MODEL=gpt-4o
# CAT411_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# CAT411_NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Optional: custom framework path
# CAT411_FRAMEWORK_ROOT=/path/to/CAT411_framework
